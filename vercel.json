{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "headers": {
        "X-Content-Type-Options": "nosniff",
        "Referrer-Policy": "strict-origin-when-cross-origin",
        "X-Frame-Options": "SAMEORIGIN",
        "Permissions-Policy": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()",
        "Content-Security-Policy": "frame-ancestors 'self'; base-uri 'self'; object-src 'none'; upgrade-insecure-requests"
      },
      "continue": true
    },
    {
      "src": "/(?:travel|travel\\.html|travel\\.js|destinations-data\\.js)/?",
      "status": 301,
      "headers": {
        "Location": "/sobre.html"
      }
    },
    {
      "src": "/(?:extensao|viral)\\.html/?",
      "status": 301,
      "headers": {
        "Location": "/sobre.html"
      }
    },
    {
      "src": "/teste-tradutor(?:/.*)?",
      "dest": "/410.html",
      "status": 410
    },
    {
      "src": "/(?:worker-video|automation|drafts|social)(?:/.*)?",
      "dest": "/410.html",
      "status": 410
    },
    {
      "src": "/api/(?:translate-video|travel-search)(?:\\.js)?/?",
      "dest": "/410.html",
      "status": 410
    },
    {
      "src": "/blog/(?:3-sites-pagar-mais-barato-e-lucrar|bilionarios-ia-dinheiro-tecnologia|brasileiros-migram-para-apartamentos-compactos|brasileiros-renda-em-dolar|dia-do-trabalhador-2026-futuro-do-trabalho|ferramentas-para-ganhar-dinheiro-online|freelancer-internacional|ganhar-dinheiro-youtube-2026-3-caminhos|ganhar-em-dolar|ingles-para-ganhar-em-dolar|inteligencia-artificial-freelancers-produtividade|melhor-notebook-trabalho-online|mercado-imobiliario-brasil-comprar-ou-investir-2026|nova-fase-ia-testes-antes-do-lancamento|ranking-bilionarios-mapa-do-futuro|setup-home-office-produtivo|tecnologia-para-freelancer|trabalho-online-home-office-milhoes|trabalho-remoto-internacional-crescimento)\\.html/?",
      "status": 301,
      "headers": {
        "Location": "/blog/"
      }
    },
    {
      "src": "/api/auth-config/?",
      "dest": "/api/auth-config.js"
    },
    {
      "src": "/api/cards/?",
      "dest": "/api/cards.js"
    },
    {
      "src": "/api/ecos-submissions/?",
      "dest": "/api/ecos-submissions.js"
    },
    {
      "src": "/api/ecos-upload-urls/?",
      "dest": "/api/ecos-upload-urls.js"
    },
    {
      "src": "/api/ecos-approved/?",
      "dest": "/api/ecos-approved.js"
    },
    {
      "src": "/api/ecos-admin-submissions/?",
      "dest": "/api/ecos-admin-submissions.js"
    },
    {
      "src": "/api/ecos-admin-submission/?",
      "dest": "/api/ecos-admin-submission.js"
    },
    {
      "src": "/api/ecos-admin-status/?",
      "dest": "/api/ecos-admin-status.js"
    },
    {
      "src": "/manga/?",
      "dest": "/manga/index.html"
    },
    {
      "src": "/manga/(.*)",
      "dest": "/manga/$1"
    },
    {
      "src": "/cartas/?",
      "dest": "/cartas/index.html"
    },
    {
      "src": "/portfolio/?",
      "dest": "/portfolio/index.html"
    },
    {
      "src": "/personagens/?",
      "dest": "/personagens/index.html"
    },
    {
      "src": "/personagens/(.*)",
      "dest": "/personagens/$1"
    },
    {
      "src": "/videos/?",
      "dest": "/videos/index.html"
    },
    {
      "src": "/videos/(.*)",
      "dest": "/videos/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}
