{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/auth-config/?",
      "dest": "/api/auth-config.js"
    },
    {
      "src": "/api/cards/?",
      "dest": "/api/cards.js"
    },
    {
      "src": "/manga/?",
      "dest": "/manga/index.html"
    },
    {
      "src": "/manga/(.*)",
      "dest": "/manga/$1"
    },
    {
      "src": "/cartas/?",
      "dest": "/cartas/index.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}
